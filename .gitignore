# ============================================
# Only track app_parallel_IO/src/ source files
# ============================================

# Ignore everything at root
/*
# Whitelist: these are tracked
!.gitignore
!README.md
!app_parallel_IO/

# Ignore everything inside app_parallel_IO except src/
app_parallel_IO/*
!app_parallel_IO/src/

# Inside src, ignore everything by default
app_parallel_IO/src/*
# Whitelist: actual source files
!app_parallel_IO/src/main.c
!app_parallel_IO/src/CMakeLists.txt
!app_parallel_IO/src/lscript.ld
!app_parallel_IO/src/UserConfig.cmake
!app_parallel_IO/src/app.yaml
!app_parallel_IO/src/Empty_applicationExample.cmake
